# =============================================================================
# 3. SERVER CONFIGURATION
# =============================================================================
# Production environment flag
NODE_ENV=production
APP_ENV=production

# Server Port
# Local: 8080
# Render: 3000 (or auto-assigned)
PORT=3000

# =============================================================================
# 4. EMAIL SERVICE CONFIGURATION (Mailgun)
