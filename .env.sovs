# =============================================================================
# 5. SECURITY CONFIGURATION
# =============================================================================
# CORS - Allowed hosts for cross-origin requests
# Use * for development, specific domains for production
CORS_ALLOWED_HOSTS=*

# Rate Limiting
# Auth endpoints: 5 requests per 15 minutes
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=5

# Password Security
BCRYPT_COST_FACTOR=12

# =============================================================================
# 6. VERIFICATION CODE CONFIGURATION
# =============================================================================
# Email verification codes
CODE_LENGTH=6
CODE_EXPIRATION_MS=600000
CODE_CLEANUP_INTERVAL_MS=300000

# =============================================================================
# 7. LOGGING & MONITORING
# =============================================================================
# Log Level: error, warn, info, debug
LOG_LEVEL=info

# Enable/Disable request logging
MORGAN_ENABLED=true

# =============================================================================
# 8. ANDROID APP CONFIGURATION
# =============================================================================
# Backend API URL for Android app
# Development: http://10.0.2.2:8080 (Android emulator)
# Production: https://sovs-backend.onrender.com
BACKEND_API_URL=https://sovs-backend.onrender.com

# =============================================================================
# 9. DEPLOYMENT INFORMATION
# =============================================================================
# These values are for reference and documentation
# They should match your Render deployment settings
DEPLOYMENT_PLATFORM=Render
DEPLOYMENT_REGION=us-east
DATABASE_VERSION=PostgreSQL 15+
NODE_VERSION=24.x
EXPRESS_VERSION=4.21.0

