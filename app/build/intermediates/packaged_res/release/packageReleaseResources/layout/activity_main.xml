<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    tools:context=".ui.MainActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp">

        <ImageView
            android:layout_width="150dp"
            android:layout_height="150dp"
            android:src="@drawable/ic_sov_logo"
            android:contentDescription="SOVS Logo"
            android:layout_marginBottom="24dp"/>

        <TextView
            android:id="@+id/tvWelcome"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Welcome to SOVS"
            android:textSize="32sp"
            android:textStyle="bold"
            android:textColor="@color/on_background"
            android:gravity="center"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Secure Online Voting System"
            android:textSize="16sp"
            android:layout_marginTop="8dp"
            android:textColor="@color/on_background_secondary"
            android:gravity="center"
            android:layout_marginBottom="48dp"/>

        <Button
            android:id="@+id/btnLogin"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Login"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp"/>

        <Button
            android:id="@+id/btnRegister"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Register"
            android:textSize="16sp"
            android:textStyle="bold"
            style="@style/Widget.Material3.Button.OutlinedButton"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Choose System Theme"
            android:layout_marginTop="64dp"
            android:textStyle="bold"
            android:textColor="@color/on_background_secondary"
            android:textSize="12sp"
            android:textAllCaps="true"
            android:letterSpacing="0.1"/>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="12dp">

            <Button
                android:id="@+id/btnLightTheme"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Light"
                android:layout_marginEnd="8dp"
                style="@style/Widget.Material3.Button.TextButton"
                android:textColor="@color/primary"/>

            <View
                android:layout_width="1dp"
                android:layout_height="24dp"
                android:background="@color/divider"
                android:layout_gravity="center_vertical"/>

            <Button
                android:id="@+id/btnDarkTheme"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Dark"
                android:layout_marginStart="8dp"
                style="@style/Widget.Material3.Button.TextButton"
                android:textColor="@color/primary"/>

        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>