<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/background">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="System Statistics"
                android:textSize="28sp"
                android:textStyle="bold"
                android:gravity="center"
                android:textColor="@color/on_background"
                android:layout_marginBottom="24dp" />

            <!-- Overview Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/card_background">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="User Overview"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/primary"
                        android:layout_marginBottom="12dp" />

                    <TextView
                        android:id="@+id/tvTotalVoters"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Total Voters: --"
                        android:textColor="@color/on_background"
                        android:layout_marginBottom="4dp"/>

                    <TextView
                        android:id="@+id/tvTotalCandidates"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Total Candidates: --"
                        android:textColor="@color/on_background"
                        android:layout_marginBottom="4dp"/>

                    <TextView
                        android:id="@+id/tvMaleVoters"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Male Users: --"
                        android:textColor="@color/on_background"
                        android:layout_marginBottom="4dp"/>

                    <TextView
                        android:id="@+id/tvFemaleVoters"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Female Users: --"
                        android:textColor="@color/on_background"
                        android:layout_marginBottom="4dp"/>

                    <TextView
                        android:id="@+id/tvDisabilityCount"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Disability Status: --"
                        android:textColor="@color/on_background" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Results Summary Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/card_background">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Election Performance"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/primary"
                        android:layout_marginBottom="12dp" />

                    <ListView
                        android:id="@+id/lvTurnout"
                        android:layout_width="match_parent"
                        android:layout_height="300dp"
                        android:divider="@color/divider"
                        android:dividerHeight="1dp"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <Button
                android:id="@+id/btnBack"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Back to Dashboard"
                android:textStyle="bold" />

        </LinearLayout>

        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:visibility="gone" />

    </FrameLayout>
</ScrollView>