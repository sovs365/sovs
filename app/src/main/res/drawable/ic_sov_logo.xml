    <path
        android:pathData="M100,100m-90,0a90,90 0,1 1,180 0a90,90 0,1 1,-180 0"
        android:fillColor="#FFFFFF"/>
    <!-- Voting Box Shape -->
    <path
        android:pathData="M60,80 L140,80 L140,140 L60,140 Z"
        android:fillColor="#6200EE"/>
    <!-- Slot on top of box -->
    <path
        android:pathData="M80,75 L120,75"
        android:strokeWidth="6"
        android:strokeColor="#6200EE"
        android:strokeLineCap="round"/>
    <!-- Checkmark inside box -->
    <path
        android:pathData="M80,110 L95,125 L125,95"
        android:strokeWidth="10"
        android:strokeColor="#FFFFFF"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"/>
    <!-- Text SOVS below -->
    <path
        android:pathData="M70,165 L80,165"
        android:strokeWidth="2"
        android:strokeColor="#6200EE"/>
</vector>